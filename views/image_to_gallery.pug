extends layout

block content
  h1= title

  if success
    div(class='alert alert-success') #{success}

  if errors.length
    div(class='alert alert-danger')
      ul(class='mb-0')
        each error in errors
          li= error.msg

  form(method='POST', action='/images/image_to_gallery')
    div(class='mb-3')
      label(for='name', class='form-label') Image Name
      input(type='text', id='name', name='name', class='form-control', value=image.name || '')

    div(class='mb-3')
      label(for='description', class='form-label') Description
      textarea(id='description', name='description', class='form-control', rows='2')= image.description || ''

    div(class='mb-3')
      label(for='path', class='form-label') Select uploaded file
      select(id='path', name='path', class='form-select')
        option(value='') -- Select file --
        each file in files
          option(value=file, selected=image.path === file) #{file}

    div(class='mb-3')
      label(for='gallery', class='form-label') Select gallery
      select(id='gallery', name='gallery', class='form-select')
        option(value='') -- Select gallery --
        each gallery in galleries
          option(value=gallery._id, selected=image.gallery == gallery._id.toString())
            | #{gallery.name} (#{gallery.owner ? gallery.owner.username : 'no owner'})

    button(type='submit', class='btn btn-primary') Add to Gallery

  hr
  a(href='/images') ← Back to images