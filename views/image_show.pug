extends layout

block content
  h1= title

  div(class='text-center')
    img(src='/images/' + image.path, class='img-fluid rounded', alt=image.name, style='max-height:80vh')

  div(class='mt-3')
    p(class='text-muted')= image.description
    a(href='/galleries/gallery_browse?gallery=' + galleryId, class='btn btn-secondary') ← Back to gallery